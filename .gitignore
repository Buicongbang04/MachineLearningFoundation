# Datasets (large files not committed; document them in datasets/README.md instead)
datasets/*.csv
datasets/*.zip
datasets/*.tar.gz
datasets/*.npy
datasets/*.parquet
!datasets/.gitkeep
!datasets/README.md

# Logs and outputs
*.log
reports/*.html
reports/*.pdf
!reports/.gitkeep

# Generated project outputs (from `python src/train.py` runs)
projects/*/results/*.json
projects/*/results/*.csv
projects/*/results/*.npy
projects/*/results/*.pkl
!projects/*/results/.gitkeep

